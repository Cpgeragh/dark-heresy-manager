rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================
    // HELPER FUNCTIONS
    // ============================

    // Returns true if the authenticated user is the owner of the given userId,
    // or if their device is linked to that owner via userLinks.
    function playerOwnsOrLinked(ownerId) {
      return request.auth != null && (
        request.auth.uid == ownerId ||
        (
          exists(/databases/$(database)/documents/userLinks/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/userLinks/$(request.auth.uid)).data.primaryUid == ownerId
        )
      );
    }

    // Returns true if the authenticated user is the DM with the given dmId,
    // or if their device is linked to that DM via userLinks.
    function dmOwnsOrLinked(dmId) {
      return request.auth != null && (
        request.auth.uid == dmId ||
        (
          exists(/databases/$(database)/documents/userLinks/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/userLinks/$(request.auth.uid)).data.primaryUid == dmId
        )
      );
    }

    // ============================
    // USERS
    // ============================
    match /users/{userId} {
      allow read, create, update:
        if request.auth != null &&
           request.auth.uid == userId;
    }

    // ============================
    // USER PROFILES (public first-name directory)
    // ============================
    // Readable by any authenticated user so DMs and party members can display
    // the owner's first name on character sheets (consistent with campaigns and
    // characters, which are already authed-readable). Only the owner can write,
    // and only a single non-empty firstName field — first name only, by design,
    // for data protection.
    match /userProfiles/{userId} {
      allow read: if request.auth != null;
      allow create, update:
        if playerOwnsOrLinked(userId) &&
           request.resource.data.keys().hasOnly(['firstName']) &&
           request.resource.data.firstName is string &&
           request.resource.data.firstName.size() > 0 &&
           request.resource.data.firstName.size() <= 50;
      allow delete: if false;
    }

    // ============================
    // CAMPAIGNS
    // ============================
    match /campaigns/{campaignId} {

      // Any authenticated user can read campaign metadata (name, dmId, memberIds).
      // Sensitive data lives in characters and sessions, which are separately restricted.
      allow read: if request.auth != null;

      allow create:
        if request.auth != null &&
           request.resource.data.dmId == request.auth.uid;

      // DM (or a linked device) can update any campaign field (except transferring ownership).
      allow update:
        if dmOwnsOrLinked(resource.data.dmId) &&
           (
             !("dmId" in request.resource.data) ||
             request.resource.data.dmId == resource.data.dmId
           );

      // DM (or a linked device) can delete their campaign (cascading delete handled client-side).
      allow delete:
        if dmOwnsOrLinked(resource.data.dmId);

      // Any authenticated user can add themselves to memberIds (claim flow).
      // Guards: only memberIds may change, they must be in the result, and no
      // existing members may be removed.
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
           request.auth.uid in request.resource.data.get('memberIds', []) &&
           request.resource.data.get('memberIds', []).hasAll(resource.data.get('memberIds', []));

      // Identity reclaim: allow transferring dmId to the reclaimer's new uid
      // when a valid reclaim document confirms they're taking over the old dmId.
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dmId']) &&
           request.resource.data.dmId == request.auth.uid &&
           exists(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid
             == resource.data.dmId;

      // Identity reclaim (player): swap the old uid out of memberIds and the new uid in.
      // Guards: only memberIds changes; new uid is present; old uid is absent;
      // every other previous member is still present (no one else was removed).
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
           request.auth.uid in request.resource.data.get('memberIds', []) &&
           exists(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)) &&
           !(get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid
               in request.resource.data.get('memberIds', [])) &&
           request.resource.data.get('memberIds', []).hasAll(
             resource.data.get('memberIds', []).removeAll([
               get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid
             ])
           );

      // ============================
      // CHARACTERS
      // ============================
      match /characters/{characterId} {

        function dmOwnsCampaign() {
          let camp = get(/databases/$(database)/documents/campaigns/$(campaignId));
          return camp != null && dmOwnsOrLinked(camp.data.dmId);
        }

        // Any authenticated user can read characters (needed for party overview
        // and claim preview before membership is established).
        allow read, list: if request.auth != null;

        allow create:
          if dmOwnsCampaign() &&
             request.resource.data.userId == null &&
             request.resource.data.isEditableByPlayer == false &&
             request.resource.data.recoveryCode is string;

        allow update:
          if (
            dmOwnsCampaign()
          ) ||
          (
            request.auth != null &&
            resource != null &&
            resource.data != null &&
            playerOwnsOrLinked(resource.data.userId) &&
            resource.data.isEditableByPlayer == true &&
            (
              !("userId" in request.resource.data) ||
              request.resource.data.userId == resource.data.userId
            ) &&
            (
              !("isEditableByPlayer" in request.resource.data) ||
              request.resource.data.isEditableByPlayer == resource.data.isEditableByPlayer
            ) &&
            (
              !("recoveryCode" in request.resource.data) ||
              request.resource.data.recoveryCode == resource.data.recoveryCode
            )
          );

        // Players can claim an unclaimed character (set userId to own UID, nothing else).
        allow update:
          if request.auth != null &&
             resource.data.userId == null &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']) &&
             request.resource.data.userId == request.auth.uid;

        // Identity reclaim: allow transferring userId to the reclaimer's new uid
        // when a valid reclaim document confirms they're taking over the old userId.
        allow update:
          if request.auth != null &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']) &&
             request.resource.data.userId == request.auth.uid &&
             exists(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)) &&
             resource.data.userId ==
               get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid;

        allow delete: if dmOwnsCampaign();

        // ============================
        // CLAIM LOGS
        // ============================
        match /claimLog/{logId} {

          function dmOwnsCampaign() {
            let camp = get(/databases/$(database)/documents/campaigns/$(campaignId));
            return camp != null && dmOwnsOrLinked(camp.data.dmId);
          }

          allow read, list: if dmOwnsCampaign();

          allow create:
            if (
              // DM writes force-assign / force-release only
              dmOwnsCampaign() &&
              ("actorUid" in request.resource.data) &&
              request.resource.data.actorUid == request.auth.uid &&
              ("action" in request.resource.data) &&
              request.resource.data.action in ["force-assign", "force-release"]
            )
            ||
            (
              // Player writes claim / release, scoped to their own character
              request.auth != null &&
              ("actorUid" in request.resource.data) &&
              request.resource.data.actorUid == request.auth.uid &&
              (
                (
                  request.resource.data.action == "claim" &&
                  get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId)).data.userId == null
                ) ||
                (
                  request.resource.data.action == "release" &&
                  playerOwnsOrLinked(
                    get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId)).data.userId
                  )
                )
              )
            );

          allow update: if false;
          allow delete: if false;
        }
      }
    }

    // ============================
    // recoveryIndex — top-level
    // ============================
    match /recoveryIndex/{code} {

      // Any authenticated user can read or query recovery codes.
      allow get: if request.auth != null;
      allow list: if request.auth != null;

      allow create, update:
        if request.auth != null &&
           ("campaignId" in request.resource.data) &&
           ("characterId" in request.resource.data) &&
           exists(/databases/$(database)/documents/campaigns/$(request.resource.data.campaignId)) &&
           dmOwnsOrLinked(
             get(/databases/$(database)/documents/campaigns/$(request.resource.data.campaignId))
               .data.dmId
           ) &&
           (request.method == "create" ||
            (exists(/databases/$(database)/documents/campaigns/$(resource.data.campaignId)) &&
             dmOwnsOrLinked(
               get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId))
                 .data.dmId
             )));

      allow delete:
        if exists(/databases/$(database)/documents/campaigns/$(resource.data.campaignId)) &&
           dmOwnsOrLinked(
             get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId))
               .data.dmId
           );
    }

    // ============================
    // IDENTITY RECOVERY — reverse lookup (code → uid + role)
    // ============================
    // Readable by authenticated users so the reclaim flow can look up a code.
    // Only the owner can create or delete their own entry.
    match /identityRecovery/{code} {
      allow get:    if request.auth != null;
      allow list:   if false;
      allow create: if request.auth != null &&
                       playerOwnsOrLinked(request.resource.data.uid);
      allow delete: if request.auth != null &&
                       playerOwnsOrLinked(resource.data.uid);
      // Identity reclaim: allow transferring this code's uid to the reclaimer's
      // new uid when a valid reclaim document confirms the handshake.
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid']) &&
           request.resource.data.uid == request.auth.uid &&
           get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid
             == resource.data.uid;
    }

    // ============================
    // IDENTITY SECRET — proof store (uid → code), rule-side only
    // ============================
    // Never readable by clients — only accessed via get() in security rule
    // evaluation when verifying a reclaim attempt.
    match /identitySecret/{uid} {
      // Owner or a linked device can read/write — linked devices need this to
      // reveal and rotate the primary account's recovery code from Settings.
      allow read:  if playerOwnsOrLinked(uid);
      allow write: if playerOwnsOrLinked(uid);
    }

    // ============================
    // IDENTITY RECLAIMS — temporary proof documents during identity migration
    // ============================
    // Written by the reclaimer to prove they know the old uid's secret code.
    // The create rule verifies the code against identitySecret before allowing it.
    // Deleted by the reclaimer once migration is complete.
    match /identityReclaims/{uid} {
      // Owner can read their own reclaim document (needed during the migration flow).
      allow read:   if request.auth != null && uid == request.auth.uid;
      // Owner can initiate a reclaim — only if their provided code matches the
      // secret stored for the old uid they're claiming.
      allow create:
        if request.auth != null &&
           uid == request.auth.uid &&
           get(/databases/$(database)/documents/identitySecret/$(request.resource.data.oldUid)).data.code
             == request.resource.data.code;
      // Owner can delete once migration is done.
      allow delete: if request.auth != null && uid == request.auth.uid;
      allow update: if false;
    }

    // ============================
    // USER LINKS — multi-device access
    // ============================
    // A secondary device writes its own UID as the document key, with
    // primaryUid pointing to the account it is linked to.
    // Maximum 3 linked devices per primary UID is enforced client-side.
    match /userLinks/{uid} {
      // A device can read its own link doc.
      allow get: if request.auth != null && uid == request.auth.uid;
      // Authenticated users can query links by primaryUid — needed to enforce
      // the 3-device cap during linking. Doc ids are opaque anonymous uids.
      allow list: if request.auth != null;
      allow delete: if request.auth != null && uid == request.auth.uid;
      allow create, update:
        if request.auth != null &&
           uid == request.auth.uid &&
           request.resource.data.primaryUid is string &&
           request.resource.data.primaryUid != request.auth.uid &&
           exists(/databases/$(database)/documents/linkProofs/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/linkProofs/$(request.auth.uid)).data.primaryUid
             == request.resource.data.primaryUid;
    }

    // ============================
    // LINK PROOFS — temporary proof that the linker knows the target account's
    // recovery code. The create rule verifies the supplied code against
    // identitySecret; the userLinks create rule then requires a matching proof.
    // The proof is owner-readable only and deleted right after linking.
    // ============================
    match /linkProofs/{uid} {
      allow read: if request.auth != null && uid == request.auth.uid;
      allow create:
        if request.auth != null &&
           uid == request.auth.uid &&
           request.resource.data.keys().hasOnly(['primaryUid', 'code']) &&
           get(/databases/$(database)/documents/identitySecret/$(request.resource.data.primaryUid)).data.code
             == request.resource.data.code;
      allow delete: if request.auth != null && uid == request.auth.uid;
      allow update: if false;
    }

    // ============================
    // SESSIONS
    // ============================
    match /campaigns/{campaignId}/sessions/{sessionId} {

      function dmOwnsCampaign() {
        return dmOwnsOrLinked(
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.dmId
        );
      }

      // Any authenticated user can read sessions.
      allow read, list: if request.auth != null;
      allow create, update, delete: if dmOwnsCampaign();
    }

    // ============================
    // MESSAGES
    // Threads are keyed by characterId — one thread per character, not per player.
    // ============================
    match /campaigns/{campaignId}/threads/{characterId} {

      function dmOwnsMessagingCampaign() {
        return dmOwnsOrLinked(
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.dmId
        );
      }

      // The player who owns this character — or a linked device — can access the thread.
      function playerOwnsCharacter() {
        return playerOwnsOrLinked(
          get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId))
            .data.userId
        );
      }

      // DM reads all thread summaries; player reads only their own character's thread
      allow read: if dmOwnsMessagingCampaign() || playerOwnsCharacter();

      // DM or the character owner can create/update the summary (sendMessage + markRead)
      allow create, update: if dmOwnsMessagingCampaign() || playerOwnsCharacter();

      // Only DM can delete a thread summary (clear chat)
      allow delete: if dmOwnsMessagingCampaign();

      match /messages/{messageId} {
        // DM reads all; player reads only their own character's thread messages
        allow read: if dmOwnsMessagingCampaign() || playerOwnsCharacter();

        // DM or the character owner can send messages; fromUid must match sender
        allow create: if (dmOwnsMessagingCampaign() || playerOwnsCharacter()) &&
                         request.resource.data.fromUid == request.auth.uid;

        // DM can delete messages (clear chat); nobody can edit
        allow delete: if dmOwnsMessagingCampaign();
        allow update: if false;
      }
    }

    // ============================
    // XP PROPOSALS
    // ============================
    match /campaigns/{campaignId}/characters/{characterId}/xpProposals/{proposalId} {

      function dmOwnsCampaign() {
        return dmOwnsOrLinked(
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.dmId
        );
      }

      allow read, list:
        if dmOwnsCampaign() ||
        playerOwnsOrLinked(
          get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId))
            .data.userId
        );

      allow create:
        if request.auth != null &&
           request.resource.data.playerId == request.auth.uid &&
           request.resource.data.status == "pending" &&
           playerOwnsOrLinked(
             get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId))
               .data.userId
           );

      allow update, delete: if dmOwnsCampaign();
    }

    // Required for collectionGroup("characters") queries — restricted to own characters only.
    match /{path=**}/characters/{characterId} {
      allow read: if playerOwnsOrLinked(resource.data.userId);
    }

    // All unlisted paths are denied by default.
  }
}
