rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------
    // USERS
    // --------------------
    match /users/{userId} {
      allow read, write: if request.auth != null &&
                         request.auth.uid == userId;
    }

    // --------------------
    // CAMPAIGNS
    // --------------------
    match /campaigns/{campaignId} {

      // Any authenticated user may read campaigns
      allow read: if request.auth != null;

      // Only DM may create/update a campaign
      allow create, update: if request.auth != null &&
                            request.resource.data.dmId == request.auth.uid;

      // --------------------
      // CHARACTERS
      // --------------------
      match /characters/{characterId} {

        allow read: if request.auth != null;

        // Helper functions
        function isDM() {
          return request.auth != null &&
            request.auth.uid ==
              get(/databases/$(database)/documents/campaigns/$(campaignId)).data.dmId;
        }

        function isOwner() {
          return request.auth != null &&
                 request.resource.data.userId == request.auth.uid;
        }

        // DM full control
        allow create, update, delete: if isDM();

        // Player can update only their own editable character
        allow update: if isOwner() &&
                       request.resource.data.isEditableByPlayer == true;

        // --------------------
        // CLAIM LOGS
        // --------------------
        match /claimLog/{logId} {

          // Only DM can read logs
          allow read: if isDM();

          // DM can create any log entry
          // Player can create only minimal entries:
          // - action: "claim" | "release"
          // - actorUid == request.auth.uid
          allow create: if isDM() ||
            (
              request.auth != null &&
              request.resource.data.actorUid == request.auth.uid &&
              request.resource.data.action in ['claim', 'release']
            );
        }
      }
    }
  }
}