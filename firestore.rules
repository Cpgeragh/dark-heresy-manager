rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------
    // USERS
    // --------------------
    match /users/{userId} {
      allow read, write: if request.auth != null &&
                         request.auth.uid == userId;
    }

    // --------------------
    // RECOVERY INDEX
    // --------------------
    match /recoveryIndex/{code} {

      // Any authenticated user may read (needed for claiming)
      allow read: if request.auth != null;

      // Utility: check if requester is the DM for the associated campaign.
      function isDMForTarget() {
        return request.auth != null &&
          get(/databases/$(database)/documents/campaigns/$(request.resource.data.campaignId)).data.dmId
            == request.auth.uid;
      }

      /**
       * DM dashboard creates characters AND writes to recoveryIndex.
       * So DM must be allowed to create/update/delete entries.
       */
      allow create, update, delete: if isDMForTarget();
    }

    // --------------------
    // CAMPAIGNS
    // --------------------
    match /campaigns/{campaignId} {

      allow read: if request.auth != null;

      allow create, update: if request.auth != null &&
                            request.resource.data.dmId == request.auth.uid;

      // --------------------
      // CHARACTERS
      // --------------------
      match /characters/{characterId} {

        allow read: if request.auth != null;

        function isDM() {
          return request.auth != null &&
            request.auth.uid ==
              get(/databases/$(database)/documents/campaigns/$(campaignId)).data.dmId;
        }

        function isOwner() {
          return request.auth != null &&
                 resource.data.userId == request.auth.uid;
        }

        // DM full control
        allow create, update, delete: if isDM();

        // Player updates ONLY if they own it AND editing is enabled
        allow update: if isOwner() &&
                       request.resource.data.isEditableByPlayer == true;

        // --------------------
        // CLAIM LOGS
        // --------------------
        match /claimLog/{logId} {

          // DM may read all logs
          allow read: if isDM();

          // DM can create any log entry
          allow create: if isDM()
            ||
            (
              request.auth != null &&
              request.resource.data.actorUid == request.auth.uid &&
              request.resource.data.action in ['claim', 'release']
            );

          allow update, delete: if false;
        }
      }
    }
  }
}