rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================
    // USERS
    // ============================
    match /users/{userId} {
      allow read, create, update:
        if request.auth != null &&
           request.auth.uid == userId;
    }

    // ============================
    // CAMPAIGNS
    // ============================
    match /campaigns/{campaignId} {

      // Any authenticated user can read campaign metadata (name, dmId, memberIds).
      // Sensitive data lives in characters and sessions, which are separately restricted.
      allow read: if request.auth != null;

      allow create:
        if request.auth != null &&
           request.resource.data.dmId == request.auth.uid;

      // DM can update any campaign field (except transferring ownership).
      allow update:
        if request.auth != null &&
           resource.data.dmId == request.auth.uid &&
           (
             !("dmId" in request.resource.data) ||
             request.resource.data.dmId == resource.data.dmId
           );

      // Any authenticated user can add themselves to memberIds (claim flow).
      // Guards: only memberIds may change, they must be in the result, and no
      // existing members may be removed.
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
           request.auth.uid in request.resource.data.get('memberIds', []) &&
           request.resource.data.get('memberIds', []).hasAll(resource.data.get('memberIds', []));

      // DM can delete their own campaign.
      allow delete:
        if request.auth != null &&
           resource.data.dmId == request.auth.uid;

      // ============================
      // CHARACTERS
      // ============================
      match /characters/{characterId} {

        function dmOwnsCampaign() {
          return request.auth != null &&
                 get(/databases/$(database)/documents/campaigns/$(campaignId))
                   .data.dmId == request.auth.uid;
        }

        function isCharacterOwner() {
          return request.auth != null &&
                 resource.data.userId == request.auth.uid;
        }

        function isMemberOfCampaign() {
          return request.auth != null &&
                 ('memberIds' in get(/databases/$(database)/documents/campaigns/$(campaignId)).data) &&
                 request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.memberIds;
        }

        // DM sees all characters in their campaign; members see all characters
        // in campaigns they belong to; owners can always read their own character.
        // Unclaimed characters are readable by any authenticated user (needed for
        // the recovery code claim preview before membership is established).
        allow read, list:
          if dmOwnsCampaign() || isCharacterOwner() || isMemberOfCampaign() ||
             (request.auth != null && resource.data.userId == null);

        allow create:
          if dmOwnsCampaign() &&
             request.resource.data.userId == null &&
             request.resource.data.isEditableByPlayer == false &&
             request.resource.data.recoveryCode is string;

        allow update:
          if (
            dmOwnsCampaign()
          ) ||
          (
            request.auth != null &&
            resource != null &&
            resource.data != null &&
            resource.data.userId == request.auth.uid &&
            resource.data.isEditableByPlayer == true &&
            (
              !("userId" in request.resource.data) ||
              request.resource.data.userId == resource.data.userId
            ) &&
            (
              !("isEditableByPlayer" in request.resource.data) ||
              request.resource.data.isEditableByPlayer == resource.data.isEditableByPlayer
            ) &&
            (
              !("recoveryCode" in request.resource.data) ||
              request.resource.data.recoveryCode == resource.data.recoveryCode
            )
          );

        // Players can claim an unclaimed character (set userId to own UID, nothing else).
        allow update:
          if request.auth != null &&
             resource.data.userId == null &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']) &&
             request.resource.data.userId == request.auth.uid;

        allow delete: if dmOwnsCampaign();

        // ============================
        // CLAIM LOGS
        // ============================
        match /claimLog/{logId} {

          function dmOwnsCampaign() {
            return request.auth != null &&
                   get(/databases/$(database)/documents/campaigns/$(campaignId))
                     .data.dmId == request.auth.uid;
          }

          allow read, list: if dmOwnsCampaign();

          allow create:
            if (
              // DM writes force-assign / force-release only
              dmOwnsCampaign() &&
              ("actorUid" in request.resource.data) &&
              request.resource.data.actorUid == request.auth.uid &&
              ("action" in request.resource.data) &&
              request.resource.data.action in ["force-assign", "force-release"]
            )
            ||
            (
              // Player writes claim / release, scoped to their own character
              request.auth != null &&
              ("actorUid" in request.resource.data) &&
              request.resource.data.actorUid == request.auth.uid &&
              (
                (
                  request.resource.data.action == "claim" &&
                  get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId)).data.userId == null
                ) ||
                (
                  request.resource.data.action == "release" &&
                  get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId)).data.userId == request.auth.uid
                )
              )
            );

          allow update: if false;
          allow delete: if false;
        }
      }
    }

    // ============================
    // recoveryIndex — top-level
    // ============================
    match /recoveryIndex/{code} {

      // Any authenticated user can look up a specific code (needed for claim flow).
      // Nobody can list all codes.
      allow get: if request.auth != null;
      allow list: if false;

      allow create, update:
        if request.auth != null &&
           ("campaignId" in request.resource.data) &&
           ("characterId" in request.resource.data) &&
           get(/databases/$(database)/documents/campaigns/$(request.resource.data.campaignId))
             .data.dmId == request.auth.uid &&
           (request.method == "create" ||
            get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId))
              .data.dmId == request.auth.uid);

      allow delete:
        if request.auth != null &&
           get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId))
             .data.dmId == request.auth.uid;
    }

    // ============================
    // SESSIONS
    // ============================
    match /campaigns/{campaignId}/sessions/{sessionId} {

      function dmOwnsCampaign() {
        return request.auth != null &&
               get(/databases/$(database)/documents/campaigns/$(campaignId))
                 .data.dmId == request.auth.uid;
      }

      function isMemberOfCampaign() {
        return request.auth != null &&
               ('memberIds' in get(/databases/$(database)/documents/campaigns/$(campaignId)).data) &&
               request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.memberIds;
      }

      // DM and campaign members can read sessions.
      allow read, list: if dmOwnsCampaign() || isMemberOfCampaign();
      allow create, update, delete: if dmOwnsCampaign();
    }

    // ============================
    // XP PROPOSALS
    // ============================
    match /campaigns/{campaignId}/characters/{characterId}/xpProposals/{proposalId} {

      function dmOwnsCampaign() {
        return request.auth != null &&
               get(/databases/$(database)/documents/campaigns/$(campaignId))
                 .data.dmId == request.auth.uid;
      }

      allow read, list:
        if dmOwnsCampaign() ||
        (
          request.auth != null &&
          get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId))
            .data.userId == request.auth.uid
        );

      allow create:
        if request.auth != null &&
           request.resource.data.playerId == request.auth.uid &&
           request.resource.data.status == "pending" &&
           get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId))
             .data.userId == request.auth.uid;

      allow update, delete: if dmOwnsCampaign();
    }

    // Required for collectionGroup("characters") queries — restricted to own characters only.
    match /{path=**}/characters/{characterId} {
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;
    }

    // All unlisted paths are denied by default.
  }
}
