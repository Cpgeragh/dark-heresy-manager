rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================
    // USERS
    // ============================
    match /users/{userId} {
      allow read, create, update, delete:
        if request.auth != null &&
           request.auth.uid == userId;
    }

    // ============================
    // CAMPAIGNS
    // ============================
    match /campaigns/{campaignId} {

      allow read, list: if request.auth != null;

      allow create:
        if request.auth != null &&
           request.resource.data.dmId == request.auth.uid;

      allow update:
        if request.auth != null &&
           resource.data.dmId == request.auth.uid &&
           (
             !("dmId" in request.resource.data) ||
             request.resource.data.dmId == resource.data.dmId
           );

      allow delete: if false;

      // ============================
      // CHARACTERS
      // ============================
      match /characters/{characterId} {

        allow read, list: if request.auth != null;

        function dmOwnsCampaign() {
          return request.auth != null &&
                 get(/databases/$(database)/documents/campaigns/$(campaignId))
                   .data.dmId == request.auth.uid;
        }

        allow create: if dmOwnsCampaign();

        allow update:
          if (
            dmOwnsCampaign()   // DM can update anything
          ) ||
          (
            request.auth != null &&
            resource != null &&
            resource.data != null &&
            resource.data.userId == request.auth.uid &&
            resource.data.isEditableByPlayer == true &&
            
            // --- SUPER Safe Field Checks - handle null request.resource.data ---
            (
              request.resource.data == null ||
              !("userId" in request.resource.data) ||
              request.resource.data.userId == resource.data.userId
            ) &&
            (
              request.resource.data == null ||
              !("isEditableByPlayer" in request.resource.data) ||
              request.resource.data.isEditableByPlayer == resource.data.isEditableByPlayer
            ) &&
            (
              request.resource.data == null ||
              !("recoveryCode" in request.resource.data) ||
              request.resource.data.recoveryCode == resource.data.recoveryCode
            )
          );

        allow delete: if dmOwnsCampaign();

        // ============================
        // CLAIM LOGS
        // ============================
        match /claimLog/{logId} {

          function dmOwnsCampaign() {
            return request.auth != null &&
                   get(/databases/$(database)/documents/campaigns/$(campaignId))
                     .data.dmId == request.auth.uid;
          }

          allow read, list: if dmOwnsCampaign();

          allow create:
            if (
              dmOwnsCampaign() &&
              ("action" in request.resource.data) &&
              request.resource.data.action in [
                "claim",
                "release",
                "force-assign",
                "force-release"
              ]
            )
            ||
            (
              request.auth != null &&
              ("actorUid" in request.resource.data) &&
              request.resource.data.actorUid == request.auth.uid &&
              request.resource.data.action in ["claim", "release"]
            );

          allow update: if false;
          allow delete: if false;
        }
      }
    }

    // ============================
    // recoveryIndex — top-level
    // ============================
    match /recoveryIndex/{code} {

      allow read, list: if request.auth != null;

      allow create, update:
        if request.auth != null &&
           ("campaignId" in request.resource.data) &&
           get(/databases/$(database)/documents/campaigns/$(request.resource.data.campaignId))
             .data.dmId == request.auth.uid &&
           // Prevent overwriting another DM's entry on update
           (request.method == "create" ||
            get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId))
              .data.dmId == request.auth.uid);

      allow delete: if false;
    }
  }
}