rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================
    // USERS
    // ============================
    match /users/{userId} {
      allow read, create, update:
        if request.auth != null &&
           request.auth.uid == userId;
    }

    // ============================
    // CAMPAIGNS
    // ============================
    match /campaigns/{campaignId} {

      // Any authenticated user can read campaign metadata (name, dmId, memberIds).
      // Sensitive data lives in characters and sessions, which are separately restricted.
      allow read: if request.auth != null;

      allow create:
        if request.auth != null &&
           request.resource.data.dmId == request.auth.uid;

      // DM can update any campaign field (except transferring ownership).
      allow update:
        if request.auth != null &&
           resource.data.dmId == request.auth.uid &&
           (
             !("dmId" in request.resource.data) ||
             request.resource.data.dmId == resource.data.dmId
           );

      // DM can delete their own campaign (cascading delete handled client-side).
      allow delete:
        if request.auth != null &&
           resource.data.dmId == request.auth.uid;

      // Any authenticated user can add themselves to memberIds (claim flow).
      // Guards: only memberIds may change, they must be in the result, and no
      // existing members may be removed.
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
           request.auth.uid in request.resource.data.get('memberIds', []) &&
           request.resource.data.get('memberIds', []).hasAll(resource.data.get('memberIds', []));

      // Identity reclaim: allow transferring dmId to the reclaimer's new uid
      // when a valid reclaim document confirms they're taking over the old dmId.
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dmId']) &&
           request.resource.data.dmId == request.auth.uid &&
           get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid
             == resource.data.dmId;

      // Identity reclaim (player): swap the old uid out of memberIds and the new uid in.
      // Guards: only memberIds changes; new uid is present; old uid is absent;
      // every other previous member is still present (no one else was removed).
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
           request.auth.uid in request.resource.data.get('memberIds', []) &&
           !(get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid
               in request.resource.data.get('memberIds', [])) &&
           request.resource.data.get('memberIds', []).hasAll(
             resource.data.get('memberIds', []).removeAll([
               get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid
             ])
           );

      // ============================
      // CHARACTERS
      // ============================
      match /characters/{characterId} {

        function dmOwnsCampaign() {
          return request.auth != null &&
                 get(/databases/$(database)/documents/campaigns/$(campaignId))
                   .data.dmId == request.auth.uid;
        }

        function isCharacterOwner() {
          return request.auth != null &&
                 resource.data.userId == request.auth.uid;
        }

        function isMemberOfCampaign() {
          return request.auth != null &&
                 ('memberIds' in get(/databases/$(database)/documents/campaigns/$(campaignId)).data) &&
                 request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.memberIds;
        }

        // Any authenticated user can read characters (needed for party overview
        // and claim preview before membership is established).
        allow read, list: if request.auth != null;

        allow create:
          if dmOwnsCampaign() &&
             request.resource.data.userId == null &&
             request.resource.data.isEditableByPlayer == false &&
             request.resource.data.recoveryCode is string;

        allow update:
          if (
            dmOwnsCampaign()
          ) ||
          (
            request.auth != null &&
            resource != null &&
            resource.data != null &&
            resource.data.userId == request.auth.uid &&
            resource.data.isEditableByPlayer == true &&
            (
              !("userId" in request.resource.data) ||
              request.resource.data.userId == resource.data.userId
            ) &&
            (
              !("isEditableByPlayer" in request.resource.data) ||
              request.resource.data.isEditableByPlayer == resource.data.isEditableByPlayer
            ) &&
            (
              !("recoveryCode" in request.resource.data) ||
              request.resource.data.recoveryCode == resource.data.recoveryCode
            )
          );

        // Players can claim an unclaimed character (set userId to own UID, nothing else).
        allow update:
          if request.auth != null &&
             resource.data.userId == null &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']) &&
             request.resource.data.userId == request.auth.uid;

        // Identity reclaim: allow transferring userId to the reclaimer's new uid
        // when a valid reclaim document confirms they're taking over the old userId.
        allow update:
          if request.auth != null &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']) &&
             request.resource.data.userId == request.auth.uid &&
             resource.data.userId ==
               get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid;

        allow delete: if dmOwnsCampaign();

        // ============================
        // CLAIM LOGS
        // ============================
        match /claimLog/{logId} {

          function dmOwnsCampaign() {
            return request.auth != null &&
                   get(/databases/$(database)/documents/campaigns/$(campaignId))
                     .data.dmId == request.auth.uid;
          }

          allow read, list: if dmOwnsCampaign();

          allow create:
            if (
              // DM writes force-assign / force-release only
              dmOwnsCampaign() &&
              ("actorUid" in request.resource.data) &&
              request.resource.data.actorUid == request.auth.uid &&
              ("action" in request.resource.data) &&
              request.resource.data.action in ["force-assign", "force-release"]
            )
            ||
            (
              // Player writes claim / release, scoped to their own character
              request.auth != null &&
              ("actorUid" in request.resource.data) &&
              request.resource.data.actorUid == request.auth.uid &&
              (
                (
                  request.resource.data.action == "claim" &&
                  get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId)).data.userId == null
                ) ||
                (
                  request.resource.data.action == "release" &&
                  get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId)).data.userId == request.auth.uid
                )
              )
            );

          allow update: if false;
          allow delete: if false;
        }
      }
    }

    // ============================
    // recoveryIndex — top-level
    // ============================
    match /recoveryIndex/{code} {

      // Any authenticated user can read or query recovery codes.
      allow get: if request.auth != null;
      allow list: if request.auth != null;

      allow create, update:
        if request.auth != null &&
           ("campaignId" in request.resource.data) &&
           ("characterId" in request.resource.data) &&
           get(/databases/$(database)/documents/campaigns/$(request.resource.data.campaignId))
             .data.dmId == request.auth.uid &&
           (request.method == "create" ||
            get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId))
              .data.dmId == request.auth.uid);

      allow delete:
        if request.auth != null &&
           get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId))
             .data.dmId == request.auth.uid;
    }

    // ============================
    // IDENTITY RECOVERY — reverse lookup (code → uid + role)
    // ============================
    // Readable by authenticated users so the reclaim flow can look up a code.
    // Only the owner can create or delete their own entry.
    match /identityRecovery/{code} {
      allow get:    if request.auth != null;
      allow list:   if false;
      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null &&
                       resource.data.uid == request.auth.uid;
      // Identity reclaim: allow transferring this code's uid to the reclaimer's
      // new uid when a valid reclaim document confirms the handshake.
      allow update:
        if request.auth != null &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid']) &&
           request.resource.data.uid == request.auth.uid &&
           get(/databases/$(database)/documents/identityReclaims/$(request.auth.uid)).data.oldUid
             == resource.data.uid;
    }

    // ============================
    // IDENTITY SECRET — proof store (uid → code), rule-side only
    // ============================
    // Never readable by clients — only accessed via get() in security rule
    // evaluation when verifying a reclaim attempt.
    match /identitySecret/{uid} {
      // Owner can read their own code (needed for the Settings page reveal/rotate flow).
      // Other users cannot read anyone else's code — the security model is intact.
      // Note: get() calls inside security rules bypass this allow read entirely,
      // so the identityReclaims verification rule is unaffected.
      allow read:  if request.auth != null && uid == request.auth.uid;
      allow write: if request.auth != null && uid == request.auth.uid;
    }

    // ============================
    // IDENTITY RECLAIMS — temporary proof documents during identity migration
    // ============================
    // Written by the reclaimer to prove they know the old uid's secret code.
    // The create rule verifies the code against identitySecret before allowing it.
    // Deleted by the reclaimer once migration is complete.
    match /identityReclaims/{uid} {
      // Owner can read their own reclaim document (needed during the migration flow).
      allow read:   if request.auth != null && uid == request.auth.uid;
      // Owner can initiate a reclaim — only if their provided code matches the
      // secret stored for the old uid they're claiming.
      allow create:
        if request.auth != null &&
           uid == request.auth.uid &&
           get(/databases/$(database)/documents/identitySecret/$(request.resource.data.oldUid)).data.code
             == request.resource.data.code;
      // Owner can delete once migration is done.
      allow delete: if request.auth != null && uid == request.auth.uid;
      allow update: if false;
    }

    // ============================
    // SESSIONS
    // ============================
    match /campaigns/{campaignId}/sessions/{sessionId} {

      function dmOwnsCampaign() {
        return request.auth != null &&
               get(/databases/$(database)/documents/campaigns/$(campaignId))
                 .data.dmId == request.auth.uid;
      }

      function isMemberOfCampaign() {
        return request.auth != null &&
               ('memberIds' in get(/databases/$(database)/documents/campaigns/$(campaignId)).data) &&
               request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.memberIds;
      }

      // Any authenticated user can read sessions.
      allow read, list: if request.auth != null;
      allow create, update, delete: if dmOwnsCampaign();
    }

    // ============================
    // MESSAGES
    // ============================
    match /campaigns/{campaignId}/threads/{playerUid} {

      function dmOwnsMessagingCampaign() {
        return request.auth != null &&
               get(/databases/$(database)/documents/campaigns/$(campaignId))
                 .data.dmId == request.auth.uid;
      }

      // DM reads all thread summaries; player reads only their own
      allow read: if dmOwnsMessagingCampaign() ||
                     (request.auth != null && request.auth.uid == playerUid);

      // DM or the player can create/update the summary (sendMessage + markRead)
      allow create, update: if dmOwnsMessagingCampaign() ||
                               (request.auth != null && request.auth.uid == playerUid);

      // Only DM can delete a thread summary (clear chat)
      allow delete: if dmOwnsMessagingCampaign();

      match /messages/{messageId} {
        // DM reads all; player reads only their own thread's messages
        allow read: if dmOwnsMessagingCampaign() ||
                       (request.auth != null && request.auth.uid == playerUid);

        // DM or the thread's player can send messages; fromUid must match sender
        allow create: if (dmOwnsMessagingCampaign() ||
                         (request.auth != null && request.auth.uid == playerUid)) &&
                         request.resource.data.fromUid == request.auth.uid;

        // DM can delete messages (clear chat); nobody can edit
        allow delete: if dmOwnsMessagingCampaign();
        allow update: if false;
      }
    }

    // ============================
    // XP PROPOSALS
    // ============================
    match /campaigns/{campaignId}/characters/{characterId}/xpProposals/{proposalId} {

      function dmOwnsCampaign() {
        return request.auth != null &&
               get(/databases/$(database)/documents/campaigns/$(campaignId))
                 .data.dmId == request.auth.uid;
      }

      allow read, list:
        if dmOwnsCampaign() ||
        (
          request.auth != null &&
          get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId))
            .data.userId == request.auth.uid
        );

      allow create:
        if request.auth != null &&
           request.resource.data.playerId == request.auth.uid &&
           request.resource.data.status == "pending" &&
           get(/databases/$(database)/documents/campaigns/$(campaignId)/characters/$(characterId))
             .data.userId == request.auth.uid;

      allow update, delete: if dmOwnsCampaign();
    }

    // Required for collectionGroup("characters") queries — restricted to own characters only.
    match /{path=**}/characters/{characterId} {
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;
    }

    // All unlisted paths are denied by default.
  }
}
